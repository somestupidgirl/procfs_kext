#!/usr/bin/env bash
#
# Build and install procfs.
#
# Usage: ./install [make args...] [load]
#
#   make args   Passed through to make, e.g. ARCH=universal
#   load        After installing, load the kext into the running kernel
#               (sudo kmutil load). Omit to load manually or on reboot.
#
# If an older build is already installed or loaded, it is unloaded and the
# kext staging cache is cleared first. macOS caches third-party kexts in the
# Auxiliary Kernel Collection, so a stale staged copy otherwise shadows a
# freshly installed build and the new version is never detected.
#
# The build artifacts are intentionally left in place after installing so they
# remain available for debugging (dSYMs, object files, etc.).
#
set -e

BUNDLE_ID="com.beako.filesystems.procfs"

# Split the optional "load" keyword out of the make arguments.
DO_LOAD=0
MAKE_ARGS=()
for arg in "$@"; do
	if [ "$arg" = "load" ]; then
		DO_LOAD=1
	else
		MAKE_ARGS+=("$arg")
	fi
done

make clean
make "${MAKE_ARGS[@]}"

if [ -d /Library/Extensions/procfs.kext ] || kmutil showloaded 2>/dev/null | grep -q "$BUNDLE_ID"; then
	echo "==> Existing procfs detected; unmounting, unloading and clearing kext staging"

	# A mounted filesystem keeps the kext busy, so unmount every procfs
	# instance before trying to unload it.
	mount | awk '/\(procfs[ ,]/ { print $3 }' | while read -r mountpoint; do
		echo "    umount $mountpoint"
		sudo umount "$mountpoint" 2>/dev/null || true
	done

	sudo kmutil unload -b "$BUNDLE_ID" 2>/dev/null || true
	# NOTE: clear-staging clears the staging area for all third-party kexts;
	# they are re-staged automatically. This is required so the new procfs
	# build is picked up instead of the previously staged copy.
	sudo kmutil clear-staging 2>/dev/null || true
fi

sudo make install-only "${MAKE_ARGS[@]}"

if [ "$DO_LOAD" -eq 1 ]; then
	echo "==> Loading procfs"
	if sudo kmutil load -p /Library/Extensions/procfs.kext; then
		kextstat | grep "$BUNDLE_ID" || true
	else
		echo "    load failed; a reboot may be required to load from the AuxKC."
	fi
else
	echo "==> procfs installed. Load it with:"
	echo "      sudo kmutil load -p /Library/Extensions/procfs.kext"
	echo "    (or reboot to load from the Auxiliary Kernel Collection)."
fi
